# Facebook Messenger Bot Configuration
# Copy this file to .env and fill in your values

# Get this from Meta Developer Console → Your App → Messenger → Access Tokens
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Set this yourself — must match what you enter in Meta Developer Console webhook settings
VERIFY_TOKEN=my_messenger_bot_token

# Required for #quiz, #trivia, and the AI lyrics fallback.
# Free, no credit card required — get a key at https://aistudio.google.com/apikey
# IMPORTANT: as of June 2026, Google requires the key to be "restricted"
# (Restrict to Gemini API only) or requests will be rejected — see SETUP.md.
GEMINI_API_KEY=AIzaYour_key_here

# Server port (default: 3000)
PORT=3000
