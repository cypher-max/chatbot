# Facebook Messenger Bot Configuration
# Copy this file to .env and fill in your values

# Get this from Meta Developer Console → Your App → Messenger → Access Tokens
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Set this yourself — must match what you enter in Meta Developer Console webhook settings
VERIFY_TOKEN=my_messenger_bot_token

# Server port (default: 3000)
PORT=3000
